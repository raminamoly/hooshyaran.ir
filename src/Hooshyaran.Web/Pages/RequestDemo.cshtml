@page "/request-demo"
@model Hooshyaran.Web.Pages.RequestDemoModel
@{
    ViewData["Title"] = "درخواست دمو";
    ViewData["Description"] = "درخواست جلسه معرفی یا دمو برای راهکارهای هوش مصنوعی سازمانی هوش‌یاران.";
    ViewData["CanonicalPath"] = "/request-demo";
}

@await Html.PartialAsync("_PageHero", new PageHeroViewModel(
    "درخواست دمو",
    "درخواست جلسه معرفی هوش‌یاران",
    "چند دقیقه زمان بگذارید تا نیاز سازمان شما را بهتر بشناسیم و جلسه‌ای دقیق‌تر و کاربردی‌تر هماهنگ کنیم.",
    "تماس با ما",
    "/contact"))

<section class="content-band">
    <div class="container demo-request-grid">
        <aside class="demo-request-aside glass-surface">
            <span class="card-icon" aria-hidden="true"><svg><use href="#icon-flow"></use></svg></span>
            <h2>بعد از ثبت چه اتفاقی می‌افتد؟</h2>
            <p>درخواست شما در پنل ادمین ثبت می‌شود و تیم هوش‌یاران برای هماهنگی زمان جلسه و بررسی سناریوی مناسب با شما تماس می‌گیرد.</p>
            <ul class="trust-list">
                <li>بررسی نیاز سازمانی و سطح آمادگی داده</li>
                <li>پیشنهاد مسیر مناسب برای شروع</li>
                <li>معرفی محصولات مرتبط با سناریوی شما</li>
            </ul>
        </aside>

        <form method="post" class="demo-request-form glass-surface">
            @if (Model.Submitted)
            {
                <div class="form-alert form-alert--success">درخواست شما ثبت شد. برای هماهنگی جلسه با شما تماس می‌گیریم.</div>
            }

            <div asp-validation-summary="ModelOnly" class="form-validation"></div>

            <div class="form-grid">
                <div>
                    <label asp-for="Input.FullName"></label>
                    <input asp-for="Input.FullName" autocomplete="name" />
                    <span asp-validation-for="Input.FullName"></span>
                </div>
                <div>
                    <label asp-for="Input.OrganizationName"></label>
                    <input asp-for="Input.OrganizationName" autocomplete="organization" />
                    <span asp-validation-for="Input.OrganizationName"></span>
                </div>
                <div>
                    <label asp-for="Input.JobTitle"></label>
                    <input asp-for="Input.JobTitle" />
                </div>
                <div>
                    <label asp-for="Input.PhoneNumber"></label>
                    <input asp-for="Input.PhoneNumber" dir="ltr" autocomplete="tel" />
                    <span asp-validation-for="Input.PhoneNumber"></span>
                </div>
                <div>
                    <label asp-for="Input.Email"></label>
                    <input asp-for="Input.Email" dir="ltr" autocomplete="email" />
                    <span asp-validation-for="Input.Email"></span>
                </div>
                <div>
                    <label asp-for="Input.PreferredTime"></label>
                    <input asp-for="Input.PreferredTime" placeholder="مثلاً شنبه صبح یا سه‌شنبه بعدازظهر" />
                </div>
            </div>

            <label asp-for="Input.NeedArea"></label>
            <input asp-for="Input.NeedArea" placeholder="مثلاً LLMOps، اتوماسیون فرایند، دستیار سازمانی" />

            <label asp-for="Input.Notes"></label>
            <textarea asp-for="Input.Notes" rows="5" placeholder="چالش، تعداد کاربران، نوع داده یا انتظارتان از جلسه را کوتاه بنویسید."></textarea>

            <button class="button button--primary" type="submit">ثبت درخواست دمو</button>
        </form>
    </div>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
