@page "/blog/{slug}"
@model Hooshyaran.Web.Pages.Blog.DetailsModel
@inject Hooshyaran.Web.Services.ICmsHtmlService CmsHtml
@{
    ViewData["Title"] = Model.Article.SeoTitle;
    ViewData["Description"] = Model.Article.SeoDescription;
    ViewData["Keywords"] = Model.Article.SeoKeywords;
    ViewData["CanonicalPath"] = $"/blog/{Model.Article.Slug}";
    ViewData["SocialImage"] = AssetOptimizer.Image(Model.Article.ImagePath);
    const string siteBaseUrl = "https://hooshyaran.ir";
    Func<string, string> absoluteUrl = value =>
        value.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
        value.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
            ? value
            : $"{siteBaseUrl}/{value.TrimStart('/')}";
    var canonicalUrl = absoluteUrl($"/blog/{Model.Article.Slug}");
    var articleImageUrl = absoluteUrl(AssetOptimizer.Image(Model.Article.ImagePath));
    ViewData["StructuredDataJson"] = new[]
    {
        System.Text.Json.JsonSerializer.Serialize(new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "Article",
            ["headline"] = Model.Article.Title,
            ["description"] = Model.Article.SeoDescription,
            ["image"] = articleImageUrl,
            ["url"] = canonicalUrl,
            ["mainEntityOfPage"] = canonicalUrl,
            ["datePublished"] = Model.Article.PublishedAt.ToString("O"),
            ["dateModified"] = Model.Article.PublishedAt.ToString("O"),
            ["inLanguage"] = "fa-IR",
            ["author"] = new Dictionary<string, object?>
            {
                ["@type"] = "Organization",
                ["name"] = string.IsNullOrWhiteSpace(Model.Article.AuthorName) ? "هوش‌یاران" : Model.Article.AuthorName
            },
            ["publisher"] = new Dictionary<string, object?>
            {
                ["@type"] = "Organization",
                ["name"] = "هوش‌یاران",
                ["logo"] = new Dictionary<string, object?>
                {
                    ["@type"] = "ImageObject",
                    ["url"] = $"{siteBaseUrl}/assets/brand/hooshyaran-logo-small.png"
                }
            }
        }),
        System.Text.Json.JsonSerializer.Serialize(new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "BreadcrumbList",
            ["itemListElement"] = new object[]
            {
                new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 1, ["name"] = "خانه", ["item"] = siteBaseUrl },
                new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 2, ["name"] = "بلاگ", ["item"] = $"{siteBaseUrl}/blog" },
                new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 3, ["name"] = Model.Article.Title, ["item"] = canonicalUrl }
            }
        })
    };
}

@await Html.PartialAsync("_PageHero", new PageHeroViewModel(
    "مقاله",
    Model.Article.Title,
    Model.Article.Summary,
    "مشاهده محصولات",
    "/products",
    "بازگشت به بلاگ",
    "/blog",
    Model.Article.ImagePath,
    Model.Article.Title,
    "page-hero--article"))

<section class="content-band">
    <div class="container article-detail-stack">
        <article class="article-body glass-surface cms-content">
            <div class="article-meta">
                <span>@Model.Article.AuthorName</span>
                <span>@PersianDateFormatter.ToPersianDate(Model.Article.PublishedAt)</span>
            </div>
            @Html.Raw(CmsHtml.ToSafeHtml(Model.Article.Body))
            @await Html.PartialAsync("_TagChips", Model.Article.BlogArticleTags.Select(item => item.Tag!).Where(tag => tag is not null))
        </article>
        <aside class="article-action-panel glass-surface">
            <h2>موضوعات مرتبط</h2>
            <p>برای اتصال مقاله به اقدام عملی، محصولات مرتبط هوش‌یاران را بررسی کنید.</p>
            <div class="article-action-panel__links" aria-label="لینک‌های مرتبط">
                <a class="text-link" href="/ai-integrator">پلتفرم هوش مصنوعی سازمانی</a>
                <a class="text-link" href="/products/llmops">LLMOPS</a>
                <a class="text-link" href="/enterprise-ai-implementation">راه اندازی هوش مصنوعی سازمانی</a>
                <a class="text-link" href="/enterprise-ai-chatbot">چت بات سازمانی</a>
                <a class="text-link" href="/ai-knowledge-base">پایگاه دانش هوشمند سازمانی</a>
                <a class="text-link" href="/private-enterprise-ai">هوش مصنوعی خصوصی برای سازمان</a>
                <a class="text-link" href="/products/workgraph-ai">WorkGraph-AI</a>
                <a class="text-link" href="/products/complaint-management-ai">Complaint Management AI</a>
                <a class="text-link" href="/request-demo">درخواست جلسه مشاوره</a>
            </div>
        </aside>
    </div>
</section>

@if (Model.RelatedArticles.Any())
{
    <section class="content-band content-band--alt">
        <div class="container">
            @await Html.PartialAsync("_SectionTitle", new SectionTitleViewModel(
                "ادامه مطالعه",
                "مقالات مرتبط",
                "چند مطلب دیگر برای کامل‌تر شدن تصویر سازمانی شما از AI."))
            <div class="article-grid">
                @foreach (var article in Model.RelatedArticles)
                {
                    <article class="article-card">
                        @if (!string.IsNullOrWhiteSpace(article.ImagePath))
                        {
                            <img class="article-card__image" src="@AssetOptimizer.Thumbnail(article.ImagePath)" alt="@article.Title" width="1100" height="619" loading="lazy" decoding="async" />
                        }
                        <p>@PersianDateFormatter.ToPersianDate(article.PublishedAt)</p>
                        <h3>@article.Title</h3>
                        <span>@article.Summary</span>
                        <a class="text-link" href="/blog/@article.Slug">ادامه مطلب</a>
                    </article>
                }
            </div>
        </div>
    </section>
}
