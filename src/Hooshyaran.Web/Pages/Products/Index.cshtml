@page "/products"
@model Hooshyaran.Web.Pages.Products.IndexModel
@{
    ViewData["Title"] = Model.Seo?.Title ?? "محصولات و نرم افزار هوش مصنوعی سازمانی";
    ViewData["Description"] = Model.Seo?.Description ?? "فهرست محصولات و نرم افزار هوش مصنوعی سازمانی هوش‌یاران برای مدیریت AI، چت بات سازمانی، پایگاه دانش، پایش مدل‌های زبانی و تحلیل داده.";
    ViewData["Keywords"] = Model.Seo?.Keywords ?? "نرم افزار هوش مصنوعی سازمانی, سیستم هوش مصنوعی سازمانی, محصولات هوش مصنوعی, چت بات سازمانی, LLMOPS فارسی";
    ViewData["CanonicalPath"] = Model.Seo?.CanonicalPath ?? "/products";

    static string ProductImage(Hooshyaran.Web.Models.Product product) =>
        !string.IsNullOrWhiteSpace(product.HeroImagePath)
            ? product.HeroImagePath
            : product.Slug switch
            {
                "llmops" => "/assets/content/article-llmops-enterprise-control.jpg",
                "workgraph-ai" => "/assets/content/article-ai-workflow-automation.jpg",
                _ => "/assets/content/home-enterprise-ai-hero.jpg"
            };

    static string CardSummary(string value, int maxLength = 92)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length <= maxLength)
        {
            return value;
        }

        return value[..maxLength].TrimEnd() + "…";
    }
}

@await Html.PartialAsync("_PageHero", new PageHeroViewModel(
    "محصولات",
    "کاتالوگ نرم افزار هوش مصنوعی سازمانی",
    "محصولات هوش‌یاران برای مدیریت مدل‌های زبانی، چت بات سازمانی، پایگاه دانش، اتوماسیون فرایندها و توسعه کنترل‌شده کاربردهای AI در سازمان طراحی شده‌اند.",
    "درخواست دمو",
    "/request-demo",
    CssClass: "page-hero--galaxy"))

<section class="content-band">
    <div class="container">
        @await Html.PartialAsync("_SectionTitle", new SectionTitleViewModel(
            "زیرساخت و عملیات هوش مصنوعی",
            "سیستم هوش مصنوعی سازمانی برای مسیرهای متفاوت اجرا",
            "هر محصول یک مسیر مشخص برای مدیریت، پایش، چت سازمانی، پایگاه دانش، اتوماسیون یا استانداردسازی استفاده سازمانی از هوش مصنوعی را پوشش می‌دهد."))
        <div class="product-grid product-grid--catalog">
            @foreach (var category in Model.Categories.Where(category => category.Products.Any()))
            {
                foreach (var product in category.Products.OrderBy(product => product.SortOrder))
                {
                    @await Html.PartialAsync("_ProductCard", new ProductCardViewModel(
                        product.PersianTitle,
                        CardSummary(product.ShortDescription),
                        category.Title,
                        $"/products/{product.Slug}",
                        "مشاهده جزئیات",
                        product.Benefits.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Take(1).ToArray(),
                        ProductImage(product)))
                }
            }
        </div>
    </div>
</section>
