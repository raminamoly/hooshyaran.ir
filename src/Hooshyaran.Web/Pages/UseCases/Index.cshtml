<section class="content-band content-band--alt" id="use-case-cards">
    <div class="container">
        @await Html.PartialAsync("_SectionTitle", new SectionTitleViewModel(
            "سناریوهای کاربردی",
            "کارت‌های ارزیابی برای انتخاب نقطه شروع",
            "هر کارت مسئله، راهکار، داده لازم، خروجی، شاخص‌های سنجش، پیچیدگی و محصول مرتبط را کنار هم می‌گذارد."))

        <div class="usecases-card-grid">
            @for (var index = 0; index < useCases.Length; index++)
            {
                var item = useCases[index];
                <article class="usecases-card">
                    <header class="usecases-card__header">
                        <span class="usecases-card__number">@(index + 1)</span>
                        <div>
                            <p>سناریو</p>
                            <h2>@item.Title</h2>
                        </div>
                    </header>

                    <div class="usecases-card__body">
                        <section>
                            <h3>مسئله</h3>
                            <p>@item.Problem</p>
                        </section>
                        <section>
                            <h3>راهکار AI</h3>
                            <p>@item.Solution</p>
                        </section>
                        <section>
                            <h3>نمونه‌ها</h3>
                            <ul>
                                @foreach (var example in item.Examples)
                                {
                                    <li>@example</li>
                                }
                            </ul>
                        </section>
                        <section>
                            <h3>داده‌های موردنیاز</h3>
                            <p>@item.RequiredData</p>
                        </section>
                        <section>
                            <h3>خروجی قابل انتظار</h3>
                            <p>@item.ExpectedOutput</p>
                        </section>
                        <section>
                            <h3>مزایا</h3>
                            <ul>
                                @foreach (var benefit in item.Benefits)
                                {
                                    <li>@benefit</li>
                                }
                            </ul>
                        </section>
                        <section>
                            <h3>شاخص‌های سنجش</h3>
                            <ul>
                                @foreach (var kpi in item.Kpis)
                                {
                                    <li>@kpi</li>
                                }
                            </ul>
                        </section>
                    </div>

                    <footer class="usecases-card__footer">
                        <span><b>پیچیدگی</b>@item.Complexity</span>
                        <span><b>زمان شروع</b>@item.Timeline</span>
                        <div class="usecases-products" aria-label="محصول مرتبط">
                            <b>محصول مرتبط</b>
                            @foreach (var product in item.Products)
                            {
                                <a href="@product.Url">@product.Name</a>
                            }
                        </div>
                    </footer>
                </article>
            }
        </div>
    </div>
</section>

