<section class="content-band content-band--alt">
    <div class="container">
        @await Html.PartialAsync("_SectionTitle", new SectionTitleViewModel(
            "نگاشت محصول",
            "هر سناریو به کدام محصول نزدیک‌تر است؟",
            "این بخش برای انتخاب سریع‌تر مسیر محصولی طراحی شده و در جلسه دمو می‌تواند بر اساس داده و فرایند واقعی سازمان دقیق‌تر شود."))
        <div class="product-map-grid">
            @foreach (var product in productMappings)
            {
                <article class="product-map-card">
                    <h3><a href="@product.Url">@product.Title</a></h3>
                    <p>@product.Text</p>
                    <div>
                        <strong>مناسب برای</strong>
                        <span>@product.Fit</span>
                    </div>
                    <a class="text-link text-link--icon" href="@product.Url">مشاهده محصول <svg aria-hidden="true"><use href="#icon-arrow-left"></use></svg></a>
                </article>
            }
        </div>
    </div>
</section>

<section class="content-band usecases-faq" aria-labelledby="usecases-faq-title">
    <div class="container faq-shell">
        <div>
            <p class="eyebrow">سوالات متداول</p>
            <h2 id="usecases-faq-title">پرسش‌های رایج درباره شروع AI در سازمان</h2>
            <p>پاسخ‌ها با نگاه اجرایی نوشته شده‌اند؛ یعنی شروع محدود، کنترل ریسک، امنیت داده و بازبینی انسانی در تصمیم‌های حساس.</p>
        </div>
        <div class="faq-list">
            @foreach (var faq in faqItems)
            {
                <details>
                    <summary>@faq.Question</summary>
                    <p>@faq.Answer</p>
                </details>
            }
        </div>
    </div>
</section>

<section class="content-band content-band--alt product-cta-band">
    <div class="container">
        @await Html.PartialAsync("_CtaSection", new CtaSectionViewModel(
            "برای سازمان خودتان از کدام سناریوی AI شروع کنید؟",
            "اگر می‌خواهید بدانید کدام کاربرد هوش مصنوعی برای سازمان شما سریع‌تر، کم‌ریسک‌تر و قابل سنجش‌تر است، از یک جلسه معرفی شروع کنید. در این جلسه می‌توانیم داده‌های موجود، فرایندهای قابل شروع، سطح پیچیدگی و شاخص‌های سنجش موفقیت را بررسی کنیم.",
            "درخواست جلسه دمو",
            "/request-demo",
            "مشاهده محصولات",
            "/products"))
    </div>
</section>

@section Scripts {
    <script type="application/ld+json">@Html.Raw(faqSchema)</script>
}
