@page "/admin/categories"
@model Hooshyaran.Web.Pages.Admin.Categories.IndexModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = Hooshyaran.Web.Models.AdminUserRoles.SuperAdmin)]
@{
    ViewData["Title"] = "مدیریت دسته‌ها";
}

<section class="admin-page">
    <div class="admin-page__header">
        <div>
            <p class="eyebrow">دسته‌ها</p>
            <h1>دسته‌بندی محصولات</h1>
        </div>
        <a class="button button--primary" href="/admin/categories/edit">دسته جدید</a>
    </div>
    <div class="admin-table-wrap glass-surface">
        <table class="admin-table">
            <thead><tr><th>عنوان</th><th>Slug</th><th>ترتیب</th><th>وضعیت</th><th>عملیات</th></tr></thead>
            <tbody>
            @foreach (var category in Model.Categories)
            {
                <tr>
                    <td>@category.Title</td>
                    <td><code>@category.Slug</code></td>
                    <td>@category.SortOrder</td>
                    <td>@(category.IsActive ? "فعال" : "غیرفعال")</td>
                    <td class="admin-actions">
                        <a class="admin-action" href="/admin/categories/edit/@category.Id" title="ویرایش">
                            <svg><use href="#admin-icon-edit"></use></svg>
                            <span class="visually-hidden">ویرایش</span>
                        </a>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@category.Id">
                            <button class="admin-action admin-action--danger" type="submit" title="حذف" onclick="return confirm('حذف شود؟ دسته‌هایی که محصول دارند حذف نمی‌شوند.')">
                                <svg><use href="#admin-icon-trash"></use></svg>
                                <span class="visually-hidden">حذف</span>
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
