@page "/admin/products"
@model Hooshyaran.Web.Pages.Admin.Products.IndexModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = Hooshyaran.Web.Models.AdminUserRoles.SuperAdmin)]
@{
    ViewData["Title"] = "مدیریت محصولات";
}

<section class="admin-page">
    <div class="admin-page__header">
        <div>
            <p class="eyebrow">محصولات</p>
            <h1>مدیریت کاتالوگ محصولات</h1>
            <p>هر محصول بعد از ذخیره در آدرس عمومی <code>/products/slug</code> نمایش داده می‌شود.</p>
        </div>
        <a class="button button--primary" href="/admin/products/edit">محصول جدید</a>
    </div>

    <div class="admin-table-wrap glass-surface">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>تصویر</th>
                    <th>محصول</th>
                    <th>دسته</th>
                    <th>Slug</th>
                    <th>ترتیب</th>
                    <th>وضعیت</th>
                    <th>عملیات</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.Products)
            {
                var product = row.Product;
                var previewImage = !string.IsNullOrWhiteSpace(product.HeroImagePath) ? product.HeroImagePath : product.LogoPath;
                <tr>
                    <td>
                        <span class="admin-thumb">
                            @if (!string.IsNullOrWhiteSpace(previewImage))
                            {
                                <img src="@AssetOptimizer.Image(previewImage)" alt="@product.PersianTitle" loading="lazy" />
                            }
                            else
                            {
                                <span>بدون تصویر</span>
                            }
                        </span>
                    </td>
                    <td>
                        <strong>@product.PersianTitle</strong>
                        <small>@product.ShortDescription</small>
                    </td>
                    <td>@product.ProductCategory?.Title</td>
                    <td><code>@product.Slug</code></td>
                    <td>@product.SortOrder</td>
                    <td>
                        <span class="admin-status @(product.IsActive ? "admin-status--live" : "admin-status--draft")">
                            @(product.IsActive ? "فعال" : "غیرفعال")
                        </span>
                        @if (product.IsFeatured)
                        {
                            <span class="admin-status admin-status--featured">ویژه</span>
                        }
                    </td>
                    <td class="admin-actions">
                        <a class="admin-action" href="@row.PublicUrl" target="_blank" rel="noopener" title="نمایش">
                            <svg><use href="#admin-icon-eye"></use></svg>
                            <span class="visually-hidden">نمایش</span>
                        </a>
                        <a class="admin-action" href="/admin/products/edit/@product.Id" title="ویرایش">
                            <svg><use href="#admin-icon-edit"></use></svg>
                            <span class="visually-hidden">ویرایش</span>
                        </a>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@product.Id">
                            <button class="admin-action admin-action--danger" type="submit" title="حذف" onclick="return confirm('محصول حذف شود؟')">
                                <svg><use href="#admin-icon-trash"></use></svg>
                                <span class="visually-hidden">حذف</span>
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
