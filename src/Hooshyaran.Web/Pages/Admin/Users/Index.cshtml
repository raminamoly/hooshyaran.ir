@page "/admin/users"
@model Hooshyaran.Web.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "مدیریت کاربران";
}

<section class="admin-page">
    <div class="admin-page__header">
        <div>
            <p class="eyebrow">تنظیمات</p>
            <h1>مدیریت کاربران پنل</h1>
            <p>کاربران نویسنده فقط به مقالات خودشان دسترسی دارند؛ SuperAdmin به همه بخش‌های پنل دسترسی دارد.</p>
        </div>
        <a class="button button--primary" href="/admin/users/edit">کاربر جدید</a>
    </div>

    <div class="admin-table-wrap glass-surface">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>کاربر</th>
                    <th>ایمیل</th>
                    <th>موبایل</th>
                    <th>نقش</th>
                    <th>اعلان دمو</th>
                    <th>وضعیت</th>
                    <th>عملیات</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td>
                        <strong>@user.DisplayName</strong>
                        <small dir="ltr">@user.UserName</small>
                    </td>
                    <td dir="ltr">@user.Email</td>
                    <td dir="ltr">@(string.IsNullOrWhiteSpace(user.MobileNumber) ? "—" : user.MobileNumber)</td>
                    <td>@(user.Role == AdminUserRoles.SuperAdmin ? "SuperAdmin" : "نویسنده")</td>
                    <td>
                        <span class="admin-status @(user.ReceiveDemoRequestNotifications ? "admin-status--live" : "admin-status--draft")">
                            @(user.ReceiveDemoRequestNotifications ? "دریافت می‌کند" : "غیرفعال")
                        </span>
                    </td>
                    <td>
                        <span class="admin-status @(user.IsActive ? "admin-status--live" : "admin-status--draft")">
                            @(user.IsActive ? "فعال" : "غیرفعال")
                        </span>
                    </td>
                    <td class="admin-actions">
                        <a class="admin-action" href="/admin/users/edit/@user.Id" title="ویرایش">
                            <svg><use href="#admin-icon-edit"></use></svg>
                            <span class="visually-hidden">ویرایش</span>
                        </a>
                        @if (user.Id != Model.CurrentUserId)
                        {
                            <form method="post" asp-page-handler="Toggle" asp-route-id="@user.Id">
                                <button class="admin-action" type="submit" title="@(user.IsActive ? "غیرفعال کردن" : "فعال کردن")">
                                    <svg><use href="#admin-icon-power"></use></svg>
                                    <span class="visually-hidden">@(user.IsActive ? "غیرفعال کردن" : "فعال کردن")</span>
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
