@page "/admin/users/edit/{id:int?}"
@model Hooshyaran.Web.Pages.Admin.Users.EditModel
@{
    ViewData["Title"] = Model.Input.Id == 0 ? "کاربر جدید" : "ویرایش کاربر";
}

<section class="admin-page">
    <div class="admin-page__header">
        <div>
            <p class="eyebrow">کاربران</p>
            <h1>@ViewData["Title"]</h1>
        </div>
        <a class="button button--secondary" href="/admin/users">بازگشت</a>
    </div>

    <form method="post" class="admin-form admin-edit-form glass-surface">
        <input asp-for="Input.Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="admin-validation"></div>

        <div class="admin-form-grid">
            <div>
                <label asp-for="Input.DisplayName"></label>
                <input asp-for="Input.DisplayName" />
                <span asp-validation-for="Input.DisplayName"></span>
            </div>
            <div>
                <label asp-for="Input.UserName"></label>
                <input asp-for="Input.UserName" dir="ltr" />
                <span asp-validation-for="Input.UserName"></span>
            </div>
            <div>
                <label asp-for="Input.Email"></label>
                <input asp-for="Input.Email" dir="ltr" />
                <span asp-validation-for="Input.Email"></span>
            </div>
            <div>
                <label asp-for="Input.Role"></label>
                <select asp-for="Input.Role" asp-items="Model.RoleOptions"></select>
                <span asp-validation-for="Input.Role"></span>
            </div>
        </div>

        <label asp-for="Input.Password"></label>
        <input asp-for="Input.Password" placeholder="برای ویرایش، اگر خالی بماند رمز تغییر نمی‌کند." />
        <span asp-validation-for="Input.Password"></span>

        <label class="admin-checkbox">
            <input asp-for="Input.IsActive" />
            <span>فعال باشد</span>
        </label>

        <div class="admin-form-actions">
            <button class="button button--primary" type="submit">ذخیره کاربر</button>
            <a class="button button--secondary" href="/admin/users">انصراف</a>
        </div>
    </form>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
