@page "/admin/articles"
@model Hooshyaran.Web.Pages.Admin.Articles.IndexModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@{
    ViewData["Title"] = "مدیریت مقالات";
}

<section class="admin-page">
    <div class="admin-page__header">
        <div>
            <p class="eyebrow">مقالات</p>
            <h1>مدیریت مقالات</h1>
        </div>
        <a class="button button--primary" href="/admin/articles/edit">مقاله جدید</a>
    </div>

    <div class="admin-table-wrap glass-surface">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>تصویر</th>
                    <th>عنوان</th>
                    <th>Slug</th>
                    <th>نویسنده</th>
                    <th>انتشار</th>
                    <th>عملیات</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.Articles)
            {
                var article = row.Article;
                <tr>
                    <td>
                        <span class="admin-thumb">
                            @if (!string.IsNullOrWhiteSpace(article.ImagePath))
                            {
                                <img src="@AssetOptimizer.Image(article.ImagePath)" alt="@article.Title" loading="lazy" />
                            }
                            else
                            {
                                <span>بدون تصویر</span>
                            }
                        </span>
                    </td>
                    <td>@article.Title</td>
                    <td><code>@article.Slug</code></td>
                    <td>@article.AuthorName</td>
                    <td>
                        <span>@(article.IsPublished ? "منتشر شده" : "پیش‌نویس")</span>
                        <small>@PersianDateFormatter.ToPersianDateTime(article.PublishedAt)</small>
                    </td>
                    <td class="admin-actions">
                        <a class="admin-action" href="@row.PublicUrl" target="_blank" rel="noopener" title="نمایش">
                            <svg><use href="#admin-icon-eye"></use></svg>
                            <span class="visually-hidden">نمایش</span>
                        </a>
                        <a class="admin-action" href="/admin/articles/edit/@article.Id" title="ویرایش">
                            <svg><use href="#admin-icon-edit"></use></svg>
                            <span class="visually-hidden">ویرایش</span>
                        </a>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@article.Id">
                            <button class="admin-action admin-action--danger" type="submit" title="حذف" onclick="return confirm('حذف شود؟')">
                                <svg><use href="#admin-icon-trash"></use></svg>
                                <span class="visually-hidden">حذف</span>
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="admin-pagination" aria-label="صفحه‌بندی مقالات">
            <a class="@(Model.PageNumber <= 1 ? "is-disabled" : null)" href="/admin/articles?pageNumber=@(Model.PageNumber - 1)">قبلی</a>
            <span>صفحه @Model.PageNumber از @Model.TotalPages - @Model.TotalItems مقاله</span>
            <a class="@(Model.PageNumber >= Model.TotalPages ? "is-disabled" : null)" href="/admin/articles?pageNumber=@(Model.PageNumber + 1)">بعدی</a>
        </nav>
    }
</section>
