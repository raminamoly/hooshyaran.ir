@page "/contact"
@model Hooshyaran.Web.Pages.ContactModel
@{
    ViewData["Title"] = Model.PageContent?.Title ?? "تماس با ما";
    ViewData["Description"] = Model.Seo?.Description ?? Model.PageContent?.SeoDescription ?? "راه‌های تماس با هوش‌یاران برای درخواست دمو، مشاوره و بررسی نیازهای سازمانی.";
    ViewData["Keywords"] = Model.Seo?.Keywords ?? Model.PageContent?.SeoKeywords ?? "";
    ViewData["CanonicalPath"] = Model.Seo?.CanonicalPath ?? "/contact";

    const string companyName = "شرکت داده‌پردازان کوشای پاسارگاد";
    const string phoneDisplay = "021-45378 - 021-88749130";
    const string emailAddress = "info@jaryansoft.com";
    const string companyAddress = "تهران، خیابان بهشتی، خ دهم قائم مقام، پلاک 24، واحد 29";
    const string mapEmbedUrl = "https://www.openstreetmap.org/export/embed.html?bbox=51.4149552%2C35.7236757%2C51.4229552%2C35.7316757&layer=mapnik&marker=35.7276757%2C51.4189552";
    const string mapExternalUrl = "https://www.openstreetmap.org/?mlat=35.7276757&mlon=51.4189552#map=17/35.7276757/51.4189552";
}

@await Html.PartialAsync("_PageHero", new PageHeroViewModel(
    "تماس با ما",
    Model.PageContent?.Title ?? "برای بررسی نیاز سازمانی خود با ما در تماس باشید",
    Model.PageContent?.Summary ?? "برای دریافت مشاوره، درخواست دمو یا بررسی سناریوی سازمانی خود از اطلاعات تماس زیر استفاده کنید.",
    "درخواست دمو",
    "/request-demo"))

<section class="content-band">
    <div class="container contact-page-shell">
        <aside class="contact-demo-strip glass-surface" aria-label="درخواست جلسه معرفی">
            <span class="contact-demo-strip__icon" aria-hidden="true"><svg><use href="#icon-calendar"></use></svg></span>
            <div>
                <strong>برای بررسی نیاز سازمانی، جلسه معرفی هماهنگ کنید.</strong>
                <p>درخواست دمو را ثبت کنید تا مسیر مناسب همکاری مشخص شود.</p>
            </div>
            <a class="button button--primary" href="/request-demo">درخواست دمو</a>
        </aside>

        <div class="contact-page-grid">
            <section class="contact-panel contact-panel--profile glass-surface" aria-labelledby="contact-title">
                <div class="contact-brand">
                    <img src="/assets/brand/hooshyaran-logo.png" alt="نشان هوش‌یاران" width="220" height="92" loading="lazy" decoding="async" />
                    <span>@companyName</span>
                </div>
                <h2 id="contact-title">اطلاعات تماس هوش‌یاران</h2>
                <p class="contact-panel__lead">هوش‌یاران راهکارهای هوش مصنوعی سازمانی، اتوماسیون هوشمند و تحلیل داده را برای فرایندهای واقعی شرکت‌ها آماده می‌کند.</p>

                <div class="contact-methods" aria-label="راه‌های ارتباط با هوش‌یاران">
                    <div class="contact-method">
                        <span class="contact-method__icon" aria-hidden="true"><svg><use href="#icon-phone"></use></svg></span>
                        <span>
                            <strong>تلفن ثابت</strong>
                            <small dir="ltr">@phoneDisplay</small>
                        </span>
                    </div>
                    <a class="contact-method" href="mailto:@emailAddress">
                        <span class="contact-method__icon" aria-hidden="true"><svg><use href="#icon-mail"></use></svg></span>
                        <span>
                            <strong dir="ltr">@emailAddress</strong>
                            <small>ایمیل برای مکاتبات کاری</small>
                        </span>
                    </a>
                    <a class="contact-method" href="@mapExternalUrl" target="_blank" rel="noopener">
                        <span class="contact-method__icon" aria-hidden="true"><svg><use href="#icon-location"></use></svg></span>
                        <span>
                            <strong>آدرس شرکت</strong>
                            <small>@companyAddress</small>
                        </span>
                    </a>
                </div>
            </section>

            <section class="map-panel glass-surface" aria-labelledby="map-title">
                <div class="map-panel__header">
                    <span class="card-icon" aria-hidden="true">
                        <svg><use href="#icon-location"></use></svg>
                    </span>
                    <div>
                        <h2 id="map-title">موقعیت شرکت روی نقشه</h2>
                        <p>@companyName</p>
                    </div>
                </div>

                <div class="online-map" aria-label="نقشه موقعیت شرکت داده‌پردازان کوشای پاسارگاد">
                    <iframe
                        title="موقعیت شرکت داده‌پردازان کوشای پاسارگاد روی نقشه"
                        src="@mapEmbedUrl"
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"></iframe>
                    <a class="online-map__open" href="@mapExternalUrl" target="_blank" rel="noopener">
                        <svg aria-hidden="true"><use href="#icon-location"></use></svg>
                        باز کردن نقشه
                    </a>
                </div>
            </section>
        </div>
    </div>
</section>
