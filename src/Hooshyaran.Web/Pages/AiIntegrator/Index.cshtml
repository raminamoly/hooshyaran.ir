@page "/ai-integrator"
@{
    ViewData["Title"] = "هوشیار | یکپارچه‌ساز هوش مصنوعی سازمان";
    ViewData["Description"] = "هوشیار پلتفرم هوش مصنوعی سازمان برای چت سازمانی، مدل‌های محلی و ابری، LLMOps، چت‌بات اختصاصی، دانشنامه، ایجنت و داشبورد مدیریتی است.";
    ViewData["Keywords"] = "هوشیار, یکپارچه‌ساز هوش مصنوعی, پلتفرم هوش مصنوعی سازمان, LLMOps سازمانی, چت سازمانی, مدل محلی, چت‌بات اختصاصی";
    ViewData["CanonicalPath"] = "/ai-integrator";
    ViewData["SocialImage"] = "/landing-pages/ai-integrator/screenshots/home-clean.webp";
}

@section Styles {
    <link rel="stylesheet" href="~/landing-pages/ai-integrator/ai-integrator.css" asp-append-version="true" />
}

<div class="ai-integrator-page">
<svg class="svg-sprite" aria-hidden="true" focusable="false">
    <symbol id="ai-icon-grid" viewBox="0 0 24 24"><path d="M4 4h6v6H4zM14 4h6v6h-6zM4 14h6v6H4zM14 14h6v6h-6z"></path></symbol>
    <symbol id="ai-icon-shield" viewBox="0 0 24 24"><path d="M12 3l7 3v5c0 4.5-2.8 8-7 10-4.2-2-7-5.5-7-10V6z"></path><path d="M9 12l2 2 4-5"></path></symbol>
    <symbol id="ai-icon-server" viewBox="0 0 24 24"><path d="M5 4h14v6H5zM5 14h14v6H5z"></path><path d="M8 7h.01M8 17h.01M12 7h4M12 17h4"></path></symbol>
    <symbol id="ai-icon-user" viewBox="0 0 24 24"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"></path><path d="M4 21a8 8 0 0 1 16 0"></path></symbol>
    <symbol id="ai-icon-users" viewBox="0 0 24 24"><path d="M9 11a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7zM2.5 21a6.5 6.5 0 0 1 13 0"></path><path d="M17 10a3 3 0 1 0 0-6M16 15.5a5.5 5.5 0 0 1 5.5 5.5"></path></symbol>
    <symbol id="ai-icon-lock" viewBox="0 0 24 24"><path d="M6 10h12v10H6z"></path><path d="M8.5 10V7.5a3.5 3.5 0 0 1 7 0V10"></path><path d="M12 14v3"></path></symbol>
    <symbol id="ai-icon-cloud" viewBox="0 0 24 24"><path d="M7 18h10a4 4 0 0 0 1-7.9A6 6 0 0 0 6.1 12 3 3 0 0 0 7 18z"></path></symbol>
    <symbol id="ai-icon-database" viewBox="0 0 24 24"><path d="M5 6c0-1.7 3.1-3 7-3s7 1.3 7 3-3.1 3-7 3-7-1.3-7-3z"></path><path d="M5 6v6c0 1.7 3.1 3 7 3s7-1.3 7-3V6"></path><path d="M5 12v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6"></path></symbol>
    <symbol id="ai-icon-file" viewBox="0 0 24 24"><path d="M7 3h7l4 4v14H7z"></path><path d="M14 3v5h4M10 13h5M10 17h5"></path></symbol>
    <symbol id="ai-icon-dashboard" viewBox="0 0 24 24"><path d="M4 5h16v14H4z"></path><path d="M8 15v-4M12 15V8M16 15v-6"></path></symbol>
    <symbol id="ai-icon-agent" viewBox="0 0 24 24"><path d="M12 4v4M12 16v4M4 12h4M16 12h4M8.5 8.5l-3-3M15.5 8.5l3-3M8.5 15.5l-3 3M15.5 15.5l3 3"></path><circle cx="12" cy="12" r="4"></circle></symbol>
    <symbol id="ai-icon-chat" viewBox="0 0 24 24"><path d="M5 5h14a3 3 0 0 1 3 3v6a3 3 0 0 1-3 3h-7l-5 4v-4H5a3 3 0 0 1-3-3V8a3 3 0 0 1 3-3z"></path></symbol>
    <symbol id="ai-icon-analytics" viewBox="0 0 24 24"><path d="M4 19h16"></path><path d="M7 16l3-4 3 2 4-7"></path><circle cx="7" cy="16" r="1"></circle><circle cx="10" cy="12" r="1"></circle><circle cx="13" cy="14" r="1"></circle><circle cx="17" cy="7" r="1"></circle></symbol>
    <symbol id="ai-icon-gpu" viewBox="0 0 24 24"><path d="M5 7h12v10H5zM17 10h3v4h-3"></path><path d="M8 4v3M12 4v3M8 17v3M12 17v3M3 10h2M3 14h2"></path><path d="M9 10h4v4H9z"></path></symbol>
    <symbol id="ai-icon-briefcase" viewBox="0 0 24 24"><path d="M4 8h16v11H4z"></path><path d="M9 8V5h6v3M4 12h16"></path></symbol>
  </svg>
    <div class="page">
        <div class="ai-integrator-main">
<section class="hero" aria-labelledby="hero-title">
        <div class="container hero-grid">
          <div class="hero-showcase" aria-label="نمای تصویری پلتفرم هوشیار">
            <div class="glass-stage">
              <div class="hero-orbit-scene" aria-hidden="true">
                <svg class="hero-link-svg" viewBox="0 0 400 400" preserveAspectRatio="none">
                  <path class="hero-link" d="M200 200 C200 150 200 98 200 56"></path>
                  <path class="hero-link" d="M200 200 C244 178 286 148 325 128"></path>
                  <path class="hero-link" d="M200 200 C244 222 286 252 325 272"></path>
                  <path class="hero-link" d="M200 200 C200 250 200 302 200 344"></path>
                  <path class="hero-link" d="M200 200 C156 222 114 252 75 272"></path>
                  <path class="hero-link" d="M200 200 C156 178 114 148 75 128"></path>
                </svg>
                <span class="hero-ring one"></span>
                <span class="hero-ring two"></span>
                <span class="hero-ring three"></span>
                <span class="hero-particle p1"></span>
                <span class="hero-particle p2"></span>
                <span class="hero-particle p3"></span>
                <span class="hero-particle p4"></span>
                <div class="hero-core">
                  <span class="core-symbol"></span>
                  <strong>هوشیار</strong>
                  <span>ارکستراسیون هوش مصنوعی</span>
                </div>
                <div class="hero-node node-models"><i></i><strong>مدل‌ها</strong><span>ابری و GPU</span></div>
                <div class="hero-node node-chatbot"><i></i><strong>چت‌بات</strong><span>سازمان‌محور</span></div>
                <div class="hero-node node-agent"><i></i><strong>ایجنت‌ها</strong><span>متصل به داده</span></div>
                <div class="hero-node node-dashboard"><i></i><strong>داشبورد</strong><span>تحلیل مدیریتی</span></div>
                <div class="hero-node node-knowledge"><i></i><strong>دانشنامه</strong><span>اسناد و RAG</span></div>
                <div class="hero-node node-data"><i></i><strong>داده‌ها</strong><span>فروش، مالی، منابع</span></div>
              </div>
            </div>
          </div>

          <div class="hero-copy">
            <h1 id="hero-title">هوشیار</h1>
            <p class="hero-subtitle">پلتفرم هوش مصنوعی سازمان</p>
            <p class="hero-lead">
              استفاده امن، کنترل‌شده و یکپارچه از هوش مصنوعی در سازمان.
            </p>
            <div class="hero-actions">
              <a class="button button-primary" href="/request-demo">درخواست جلسه دمو</a>
            </div>
          </div>
        </div>
      </section>

      <nav class="module-nav" aria-label="فهرست ماژول‌ها">
        <div class="container module-strip">
          <a href="#module-control">کنترل مرکزی</a>
          <a href="#module-chat">چت سازمانی</a>
          <a href="#module-local">مدل‌های محلی</a>
          <a href="#module-cloud">مدل‌های ابری</a>
          <a href="#module-llmops">LLMOps</a>
          <a href="#module-rag">دانشنامه</a>
          <a href="#module-agents">ایجنت‌ها</a>
          <a href="#module-chatbot">چت‌بات‌ساز</a>
          <a href="#module-dashboard">داشبوردساز</a>
          <a href="#module-usage">مصرف و هزینه</a>
          <a href="#module-access">دسترسی‌ها</a>
        </div>
      </nav>

      <section id="modules" class="modules">
        <div class="container">
          <article id="module-control" class="module-section">
            <div class="module-visual">
              <div class="browser-frame">
                <img src="~/landing-pages/ai-integrator/screenshots/home-clean.webp" alt="محیط یکپارچه سازمانی هوشیار" decoding="async" fetchpriority="high">
                <span class="frame-caption">محیط یکپارچه سازمانی</span>
              </div>
            </div>
            <div class="module-copy">
              <span class="module-index">۱</span>
              <h2>کنترل متمرکز هوش مصنوعی در سازمان</h2>
              <p>هوشیار نقطه ورود واحد برای استفاده سازمان از هوش مصنوعی است. مدیران می‌توانند وضعیت سامانه، کاربران، مدل‌ها، مصرف، سلامت زیرساخت و مسیرهای اصلی محصول را از یک پنل دنبال کنند.</p>
              <ul class="module-list">
                <li>نمای مدیریتی سلامت سرویس‌ها، منابع و فعالیت کاربران</li>
                <li>مسیر واحد برای مدل، چت، دانشنامه، ایجنت و داشبورد</li>
                <li>مناسب نصب روی زیردامنه سازمان مانند `ai.company.ir`</li>
                <li>کاهش پراکندگی ابزارها و حساب‌های هوش مصنوعی در سازمان</li>
              </ul>
            </div>
          </article>

          <article id="module-chat" class="module-section reverse">
            <div class="module-visual">
              <div class="concept-frame">
                <div class="chat-mock" role="img" aria-label="موکاپ محیط چت سازمانی هوشیار با انتخاب مدل و مکالمه">
                  <div class="chat-mock-top">
                    <div class="chat-models">
                      <span class="active">مدل محلی GPU</span>
                      <span>Claude</span>
                      <span>DeepSeek</span>
                    </div>
                    <span class="chat-status">دسترسی: مدیر فروش</span>
                  </div>
                  <div class="chat-body">
                    <aside class="chat-sidebar">
                      <strong>گفت‌وگوها</strong>
                      <div class="chat-history">
                        <span>تحلیل فروش ماه</span>
                        <span>گزارش منابع انسانی</span>
                        <span>خلاصه آیین‌نامه</span>
                        <span>پرسش از داشبورد</span>
                      </div>
                    </aside>
                    <div class="chat-thread">
                      <div class="chat-question">
                        <div class="chat-message-head">
                          <span class="chat-avatar" aria-hidden="true">
                            <svg viewBox="0 0 24 24"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"></path><path d="M4 21a8 8 0 0 1 16 0"></path></svg>
                          </span>
                          <span class="chat-speaker">مدیر فروش</span>
                        </div>
                        <p>روند فروش سه ماه اخیر را با بودجه مقایسه کن.</p>
                      </div>
                      <div class="chat-answer">
                        <div class="chat-message-head">
                          <span class="chat-avatar" aria-hidden="true">
                            <svg viewBox="0 0 24 24"><path d="M12 3v3"></path><path d="M12 18v3"></path><path d="M3 12h3"></path><path d="M18 12h3"></path><path d="M7 7l2 2"></path><path d="M15 15l2 2"></path><path d="M17 7l-2 2"></path><path d="M9 15l-2 2"></path><circle cx="12" cy="12" r="4"></circle></svg>
                          </span>
                          <span class="chat-speaker">هوشیار · مدل محلی GPU</span>
                        </div>
                        <p>فروش در خرداد ۱۸٪ بالاتر از بودجه است. بیشترین رشد مربوط به کانال سازمانی و تمدید قراردادهاست.</p>
                        <div class="chat-answer-meta">
                          <b>دیتابیس فروش</b>
                          <b>داشبورد مالی</b>
                        </div>
                      </div>
                      <div class="chat-question">
                        <div class="chat-message-head">
                          <span class="chat-avatar" aria-hidden="true">
                            <svg viewBox="0 0 24 24"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"></path><path d="M4 21a8 8 0 0 1 16 0"></path></svg>
                          </span>
                          <span class="chat-speaker">مدیر فروش</span>
                        </div>
                        <p>سه ریسک اصلی ماه بعد را هم خلاصه کن.</p>
                      </div>
                      <div class="chat-answer">
                        <div class="chat-message-head">
                          <span class="chat-avatar" aria-hidden="true">
                            <svg viewBox="0 0 24 24"><path d="M12 3v3"></path><path d="M12 18v3"></path><path d="M3 12h3"></path><path d="M18 12h3"></path><path d="M7 7l2 2"></path><path d="M15 15l2 2"></path><path d="M17 7l-2 2"></path><path d="M9 15l-2 2"></path><circle cx="12" cy="12" r="4"></circle></svg>
                          </span>
                          <span class="chat-speaker">هوشیار · دسترسی کنترل‌شده</span>
                        </div>
                        <p>افت نرخ تبدیل، تأخیر چند پرداخت بزرگ، و کاهش موجودی یک گروه محصول نیاز به پیگیری دارد.</p>
                      </div>
                      <div class="chat-input-row">
                        <span>سؤال بعدی را از داده‌های مجاز سازمان بپرسید...</span>
                        <i class="chat-send-dot"></i>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="module-copy">
              <span class="module-index">۲</span>
              <h2>چت سازمانی کارکنان و مدیران</h2>
              <p>به جای خرید و مدیریت حساب‌های پراکنده، سازمان یک محیط چت داخلی دارد که دسترسی به مدل‌ها و داده‌ها را مطابق نقش هر کاربر کنترل می‌کند.</p>
              <ul class="module-list">
                <li>تعریف کاربران و نقش‌ها برای مدل‌ها و چت‌بات‌ها</li>
                <li>امکان استفاده از مدل‌های محلی برای داده‌های حساس</li>
                <li>امکان اتصال به مدل‌های ابری برای نیازهای کم‌ریسک‌تر</li>
                <li>حفظ مسیر استفاده از هوش مصنوعی داخل چارچوب سازمان</li>
              </ul>
            </div>
          </article>

          <article id="module-local" class="module-section">
            <div class="module-visual">
              <div class="concept-frame">
                <div class="software-mock" role="img" aria-label="موکاپ مدیریت مدل‌های محلی و GPU">
                  <div class="mock-topbar">
                    <span class="mock-title">مدیریت مدل‌های محلی و GPU</span>
                    <div class="mock-actions"><span class="mock-status ok">GPU آماده</span><span class="mock-pill">سیاست مدل</span></div>
                  </div>
                  <div class="mock-body">
                    <aside class="mock-sidebar">
                      <strong>زیرساخت</strong>
                      <span class="mock-nav-item active">مدل‌های محلی</span>
                      <span class="mock-nav-item">GPU داخلی</span>
                      <span class="mock-nav-item">GPU ابری</span>
                      <span class="mock-nav-item">دسترسی</span>
                    </aside>
                    <div class="mock-content">
                      <div class="mock-grid">
                        <div class="mock-kpi"><strong>مدل‌های نصب‌شده</strong><span>متن‌باز و سازمانی</span><b>۱۲</b></div>
                        <div class="mock-kpi"><strong>ظرفیت GPU</strong><span>داخلی یا اجاره‌ای</span><b>۶۸٪</b></div>
                        <div class="mock-kpi"><strong>سیاست فعال</strong><span>داده حساس</span><b>محلی</b></div>
                      </div>
                      <div class="mock-table">
                        <div class="mock-row head"><span>مدل</span><span>مسیر اجرا</span><span>وضعیت</span></div>
                        <div class="mock-row"><span>Qwen 2.5</span><span>GPU داخلی</span><span class="mock-status ok">آماده</span></div>
                        <div class="mock-row"><span>GPT-OSS</span><span>GPU ابری داخلی</span><span class="mock-status ok">آماده</span></div>
                        <div class="mock-row"><span>DeepSeek</span><span>ظرفیت رزرو</span><span class="mock-status warn">در انتظار</span></div>
                      </div>
                      <div class="mock-split">
                        <div class="mock-panel"><strong>Readiness</strong><span>endpoint، حافظه و پاسخ آزمایشی بررسی شده‌اند.</span><div class="mock-progress"><i style="width:86%"></i></div></div>
                        <div class="mock-panel"><strong>کنترل خروج داده</strong><span>داده‌های حساس فقط به مسیر محلی ارسال می‌شوند.</span></div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="module-copy">
              <span class="module-index">۳</span>
              <h2>مدل‌های محلی و GPU داخلی</h2>
              <p>هوشیار به سازمان اجازه می‌دهد مدل‌های متن‌باز و محلی را روی GPU داخلی یا ظرفیت GPU ابری داخلی اجرا کند؛ بدون اینکه داده حساس الزاماً از محیط کنترل‌شده خارج شود.</p>
              <ul class="module-list">
                <li>مدیریت نصب، readiness و endpoint مدل‌ها</li>
                <li>پشتیبانی از GPU داخلی یا GPU اجاره‌ای</li>
                <li>قابل استفاده برای داده‌های حساس، محرمانه و عملیاتی</li>
                <li>امکان تعریف سیاست دسترسی برای هر مدل و هر گروه کاربری</li>
              </ul>
            </div>
          </article>

          <article id="module-cloud" class="module-section reverse">
            <div class="module-visual">
              <div class="concept-frame">
                <div class="software-mock" role="img" aria-label="موکاپ تنظیمات دروازه مدل‌های ابری">
                  <div class="mock-topbar">
                    <span class="mock-title">دروازه مدل‌های ابری</span>
                    <div class="mock-actions"><span class="mock-status ok">کنترل‌شده</span><span class="mock-pill">سیاست دسترسی</span></div>
                  </div>
                  <div class="mock-body">
                    <aside class="mock-sidebar">
                      <strong>مدل‌ها</strong>
                      <span class="mock-nav-item active">مدل‌های ابری</span>
                      <span class="mock-nav-item">کلیدها</span>
                      <span class="mock-nav-item">Routing</span>
                      <span class="mock-nav-item">مصرف</span>
                    </aside>
                    <div class="mock-content">
                      <div class="mock-grid">
                        <div class="mock-card"><strong>ChatGPT</strong><span>فعال برای داده غیرحساس</span><span class="mock-status ok">Online</span></div>
                        <div class="mock-card"><strong>Claude</strong><span>تحلیل متنی و اسناد</span><span class="mock-status ok">Online</span></div>
                        <div class="mock-card"><strong>Gemini</strong><span>سناریوهای عمومی</span><span class="mock-status warn">محدود</span></div>
                        <div class="mock-card"><strong>Grok</strong><span>پاسخ سریع</span><span class="mock-status ok">Online</span></div>
                        <div class="mock-card"><strong>DeepSeek</strong><span>مدل اقتصادی</span><span class="mock-status ok">Online</span></div>
                        <div class="mock-card"><strong>Qwen</strong><span>پشتیبان ابری</span><span class="mock-status ok">Online</span></div>
                      </div>
                      <div class="mock-table">
                        <div class="mock-row head"><span>مسیر</span><span>سیاست</span><span>وضعیت</span></div>
                        <div class="mock-row"><span>پرسش عمومی</span><span>Cloud first</span><span class="mock-status ok">مجاز</span></div>
                        <div class="mock-row"><span>داده محرمانه</span><span>Local only</span><span class="mock-status warn">مسدود</span></div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="module-copy">
              <span class="module-index">۴</span>
              <h2>اتصال به مدل‌های ابری</h2>
              <p>برای داده‌های غیرحساس یا سناریوهایی که کیفیت و سرعت مدل‌های ابری اهمیت دارد، هوشیار اتصال به مدل‌های شناخته‌شده را از طریق یک لایه قابل کنترل فراهم می‌کند.</p>
              <ul class="module-list">
                <li>تعریف endpoint ابری و مدیریت دسترسی کاربران</li>
                <li>استفاده همزمان از مدل‌های ابری در کنار مدل‌های محلی</li>
                <li>امکان تفکیک داده حساس و غیرحساس در سیاست استفاده</li>
                <li>کاهش نیاز به حساب‌های پراکنده و غیرقابل کنترل</li>
              </ul>
            </div>
          </article>

          <article id="module-llmops" class="module-section">
            <div class="module-visual">
              <div class="concept-frame">
                <div class="software-mock" role="img" aria-label="موکاپ کنسول LLMOps و سلامت مدل‌ها">
                  <div class="mock-topbar">
                    <span class="mock-title">کنسول LLMOps</span>
                    <div class="mock-actions"><span class="mock-status ok">Stack healthy</span><span class="mock-pill">آخرین ۵ دقیقه</span></div>
                  </div>
                  <div class="mock-body">
                    <aside class="mock-sidebar">
                      <strong>عملیات</strong>
                      <span class="mock-nav-item active">سلامت مدل‌ها</span>
