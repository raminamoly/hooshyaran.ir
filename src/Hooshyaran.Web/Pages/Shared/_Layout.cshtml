@using Microsoft.EntityFrameworkCore
@inject Hooshyaran.Web.Data.HooshyaranDbContext LayoutDbContext
@{
    var pageTitle = ViewData["Title"] as string ?? "هوش‌یاران";
    var description = ViewData["Description"] as string ?? "هوش‌یاران راهکارهای AI خصوصی، کنترل‌شده و قابل اتصال به داده‌های داخلی سازمان را طراحی و پیاده‌سازی می‌کند.";
    var keywords = ViewData["Keywords"] as string ?? "هوش مصنوعی سازمانی, راهکار AI برای شرکت‌ها, اتوماسیون هوشمند سازمانی";
    var canonicalPath = ViewData["CanonicalPath"] as string ?? Context.Request.Path.Value ?? "/";
    var footerProducts = await LayoutDbContext.Products
        .Where(product => product.IsActive)
        .OrderBy(product => product.SortOrder)
        .Take(4)
        .ToListAsync();
}
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - هوش‌یاران</title>
    <meta name="description" content="@description" />
    <meta name="keywords" content="@keywords" />
    <link rel="canonical" href="@canonicalPath" />
    <meta property="og:title" content="@pageTitle - هوش‌یاران" />
    <meta property="og:description" content="@description" />
    <meta property="og:type" content="website" />
    <script type="importmap"></script>
    <link rel="icon" type="image/svg+xml" href="~/assets/brand/favicon.svg" />
    <link rel="preload" href="~/assets/fonts/iransansx-fa-num/IRANSansXFaNum-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="~/assets/fonts/iransansx-fa-num/IRANSansXFaNum-DemiBold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="~/css/fonts.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Hooshyaran.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <svg class="icon-sprite" aria-hidden="true" focusable="false">
        <symbol id="icon-spark" viewBox="0 0 24 24">
            <path d="M12 2l1.7 5.3L19 9l-5.3 1.7L12 16l-1.7-5.3L5 9l5.3-1.7L12 2Z" />
            <path d="M19 14l.9 2.7L22 18l-2.1 1.3L19 22l-.9-2.7L16 18l2.1-1.3L19 14Z" />
        </symbol>
        <symbol id="icon-shield" viewBox="0 0 24 24">
            <path d="M12 3l7 3v5.6c0 4.3-2.8 7.6-7 9.4-4.2-1.8-7-5.1-7-9.4V6l7-3Z" />
            <path d="M9 12l2 2 4-5" />
        </symbol>
        <symbol id="icon-flow" viewBox="0 0 24 24">
            <path d="M6 7h4l4 10h4" />
            <path d="M6 17h4l4-10h4" />
            <circle cx="5" cy="7" r="2" />
            <circle cx="19" cy="7" r="2" />
            <circle cx="5" cy="17" r="2" />
            <circle cx="19" cy="17" r="2" />
        </symbol>
        <symbol id="icon-database" viewBox="0 0 24 24">
            <ellipse cx="12" cy="5" rx="7" ry="3" />
            <path d="M5 5v6c0 1.7 3.1 3 7 3s7-1.3 7-3V5" />
            <path d="M5 11v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6" />
        </symbol>
        <symbol id="icon-chart" viewBox="0 0 24 24">
            <path d="M4 19V5" />
            <path d="M4 19h16" />
            <path d="M8 15l3-4 3 2 4-7" />
        </symbol>
        <symbol id="icon-location" viewBox="0 0 24 24">
            <path d="M12 21s7-5.2 7-11a7 7 0 0 0-14 0c0 5.8 7 11 7 11Z" />
            <circle cx="12" cy="10" r="2.5" />
        </symbol>
        <symbol id="icon-mail" viewBox="0 0 24 24">
            <path d="M4 6h16v12H4z" />
            <path d="M4 7l8 6 8-6" />
        </symbol>
        <symbol id="icon-home" viewBox="0 0 24 24">
            <path d="M4 11.5 12 4l8 7.5" />
            <path d="M6.5 10.5V20h11v-9.5" />
            <path d="M10 20v-5h4v5" />
        </symbol>
        <symbol id="icon-box" viewBox="0 0 24 24">
            <path d="m12 3 8 4.5v9L12 21l-8-4.5v-9L12 3Z" />
            <path d="m4.5 8 7.5 4.2L19.5 8" />
            <path d="M12 12.2V21" />
        </symbol>
        <symbol id="icon-briefcase" viewBox="0 0 24 24">
            <path d="M9 7V5.5A1.5 1.5 0 0 1 10.5 4h3A1.5 1.5 0 0 1 15 5.5V7" />
            <path d="M5 7h14v11H5z" />
            <path d="M5 12h14" />
        </symbol>
        <symbol id="icon-book" viewBox="0 0 24 24">
            <path d="M5 5.5A2.5 2.5 0 0 1 7.5 3H20v16H7.5A2.5 2.5 0 0 0 5 21V5.5Z" />
            <path d="M5 5.5A2.5 2.5 0 0 0 2.5 3H4" />
        </symbol>
        <symbol id="icon-users" viewBox="0 0 24 24">
            <circle cx="9" cy="8" r="3" />
            <path d="M3.5 19a5.5 5.5 0 0 1 11 0" />
            <path d="M16 11a3 3 0 0 0 0-6" />
            <path d="M18 18a4.5 4.5 0 0 0-2.5-4" />
        </symbol>
        <symbol id="icon-phone" viewBox="0 0 24 24">
            <path d="M7 4h3l1 5-2 1.2a10.5 10.5 0 0 0 4.8 4.8L15 13l5 1v3c0 1.1-.9 2-2 2A14 14 0 0 1 5 6c0-1.1.9-2 2-2Z" />
        </symbol>
        <symbol id="icon-calendar" viewBox="0 0 24 24">
            <path d="M5 5h14v15H5z" />
            <path d="M8 3v4" />
            <path d="M16 3v4" />
            <path d="M5 9h14" />
        </symbol>
        <symbol id="icon-arrow-left" viewBox="0 0 24 24">
            <path d="M19 12H5" />
            <path d="m11 6-6 6 6 6" />
        </symbol>
        <symbol id="icon-server" viewBox="0 0 24 24">
            <path d="M5 4h14v6H5z" />
            <path d="M5 14h14v6H5z" />
            <path d="M8 7h.1" />
            <path d="M8 17h.1" />
            <path d="M12 7h5" />
            <path d="M12 17h5" />
        </symbol>
        <symbol id="icon-cpu" viewBox="0 0 24 24">
            <rect x="7" y="7" width="10" height="10" rx="1.5" />
            <path d="M10 3v4M14 3v4M10 17v4M14 17v4M3 10h4M3 14h4M17 10h4M17 14h4" />
            <rect x="10" y="10" width="4" height="4" rx=".8" />
        </symbol>
    </svg>
    <a class="skip-link" href="#main-content">رفتن به محتوای اصلی</a>
    <header class="site-header" data-site-header>
        <div class="container site-header__inner">
            <a class="brand-link" asp-area="" asp-page="/Index" aria-label="صفحه اصلی هوش‌یاران">
                <img src="~/assets/brand/hooshyaran-logo.png" alt="نشان هوش‌یاران" width="86" height="48" />
            </a>

            <button class="nav-toggle" type="button" aria-controls="primary-navigation" aria-expanded="false">
                <span></span>
                <span></span>
                <span></span>
                <span class="visually-hidden">باز کردن منو</span>
            </button>

            <nav class="primary-nav" id="primary-navigation" aria-label="ناوبری اصلی">
                <a href="/"><svg aria-hidden="true"><use href="#icon-home"></use></svg>خانه</a>
                <a href="/products"><svg aria-hidden="true"><use href="#icon-box"></use></svg>محصولات</a>
                <a href="/solutions"><svg aria-hidden="true"><use href="#icon-flow"></use></svg>راهکارها</a>
                <a href="/use-cases"><svg aria-hidden="true"><use href="#icon-briefcase"></use></svg>کاربردها</a>
                <a href="/blog"><svg aria-hidden="true"><use href="#icon-book"></use></svg>بلاگ</a>
                <a href="/about"><svg aria-hidden="true"><use href="#icon-users"></use></svg>درباره ما</a>
                <a href="/contact"><svg aria-hidden="true"><use href="#icon-phone"></use></svg>تماس با ما</a>
            </nav>

            <a class="button button--primary header-cta" href="/request-demo"><svg aria-hidden="true"><use href="#icon-calendar"></use></svg>درخواست دمو</a>
        </div>
    </header>

    <main id="main-content">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container site-footer__grid">
            <section class="site-footer__intro" aria-labelledby="footer-brand-title">
                <a class="brand-link brand-link--footer" asp-area="" asp-page="/Index">
                    <img src="~/assets/brand/hooshyaran-logo.png" alt="نشان هوش‌یاران" width="88" height="49" />
                    <span id="footer-brand-title">هوش‌یاران</span>
                </a>
                <p>هوش‌یاران راهکارهای AI خصوصی، کنترل‌شده و قابل اتصال به داده‌های داخلی سازمان را طراحی و پیاده‌سازی می‌کند.</p>
            </section>

            <section aria-labelledby="footer-products-title">
                <h2 id="footer-products-title"><svg aria-hidden="true"><use href="#icon-spark"></use></svg>محصولات</h2>
                @foreach (var product in footerProducts)
                {
                    <a href="/products/@product.Slug">@product.Name</a>
                }
                <a href="/products">همه محصولات</a>
            </section>

            <section aria-labelledby="footer-solutions-title">
                <h2 id="footer-solutions-title"><svg aria-hidden="true"><use href="#icon-flow"></use></svg>راهکارها</h2>
                <a href="/solutions">هوش مصنوعی سازمانی</a>
                <a href="/use-cases">کاربردها</a>
                <a href="/request-demo">درخواست دمو</a>
            </section>

            <section aria-labelledby="footer-blog-title">
                <h2 id="footer-blog-title"><svg aria-hidden="true"><use href="#icon-chart"></use></svg>بلاگ</h2>
                <a href="/blog">مقالات آموزشی</a>
                <a href="/about">درباره ما</a>
                <a href="/contact">تماس</a>
            </section>

            <section aria-labelledby="footer-contact-title">
                <h2 id="footer-contact-title"><svg aria-hidden="true"><use href="#icon-location"></use></svg>تماس</h2>
                <p>برای بررسی نیاز سازمانی و درخواست جلسه معرفی، از صفحه تماس یا درخواست دمو اقدام کنید.</p>
                <a class="text-link" href="/contact">ارتباط با هوش‌یاران</a>
            </section>
        </div>
        <div class="container site-footer__bottom">
            <span>&copy; @PersianDateFormatter.CurrentPersianYear() هوش‌یاران</span>
            <span>تمام حقوق مادی و معنوی هوش‌یاران متعلق به شرکت داده‌پردازان کوشای پاسارگاد می‌باشد.</span>
        </div>
    </footer>

    <script src="~/lib/gsap/gsap.min.js" asp-append-version="true"></script>
    <script src="~/lib/gsap/ScrollTrigger.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
