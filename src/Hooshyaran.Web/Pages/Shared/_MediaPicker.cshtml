<div class="media-picker" data-media-picker hidden aria-hidden="true">
    <button class="media-picker__backdrop" type="button" data-media-picker-close aria-label="بستن انتخاب‌گر رسانه"></button>
    <section class="media-picker__panel glass-surface" role="dialog" aria-modal="true" aria-labelledby="media-picker-title">
        <header class="media-picker__header">
            <div>
                <p class="eyebrow">رسانه‌ها</p>
                <h2 id="media-picker-title">انتخاب فایل</h2>
            </div>
            <button class="media-picker__close" type="button" data-media-picker-close aria-label="بستن">×</button>
        </header>

        <div class="media-picker__tools">
            <input data-media-picker-search type="search" placeholder="جستجوی فایل" aria-label="جستجوی فایل" />
            <input data-media-picker-upload type="file" hidden />
            <button class="button button--secondary" type="button" data-media-picker-upload-button>آپلود فایل</button>
        </div>

        <div class="media-picker__status" data-media-picker-status aria-live="polite"></div>
        <div class="media-picker__grid" data-media-picker-grid></div>
    </section>
</div>
