@page
@model IndexModel
@{
    ViewData["Title"] = Model.Seo?.Title ?? "هوش مصنوعی سازمانی برای شرکت‌ها";
    ViewData["Description"] = Model.Seo?.Description ?? "هوش‌یاران پلتفرم هوش مصنوعی سازمانی را روی زیرساخت شما راه اندازی می‌کند؛ از چت بات سازمانی و پایگاه دانش هوشمند تا مدل‌های زبانی، ایجنت و کنترل مصرف.";
    ViewData["Keywords"] = Model.Seo?.Keywords ?? "هوش مصنوعی سازمانی, پلتفرم هوش مصنوعی سازمانی, راه اندازی هوش مصنوعی سازمانی, چت بات سازمانی, پایگاه دانش هوشمند سازمانی";
    ViewData["CanonicalPath"] = Model.Seo?.CanonicalPath ?? "/";

    static string ProductImage(Hooshyaran.Web.Models.Product product) =>
        !string.IsNullOrWhiteSpace(product.HeroImagePath)
            ? product.HeroImagePath
            : product.Slug switch
            {
                "llmops" => "/assets/content/article-llmops-enterprise-control.jpg",
                "workgraph-ai" => "/assets/content/article-ai-workflow-automation.jpg",
                _ => "/assets/content/home-enterprise-ai-hero.jpg"
            };

    static string CardSummary(string value, int maxLength = 92)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length <= maxLength)
        {
            return value;
        }

        return value[..maxLength].TrimEnd() + "…";
    }
}

@await Html.PartialAsync("_PageHero", new PageHeroViewModel(
    "هوش مصنوعی سازمانی",
    "پلتفرم هوش مصنوعی سازمانی برای استفاده امن در شرکت‌ها",
    "چت بات سازمانی، پایگاه دانش هوشمند، مدل‌های زبانی، ایجنت‌ها و کنترل مصرف را روی زیرساخت سازمان خود راه اندازی کنید.",
    "درخواست جلسه معرفی",
    "/request-demo",
    "مشاهده پلتفرم هوش مصنوعی سازمانی",
    "/ai-integrator",
    "/assets/content/home-enterprise-ai-hero.jpg",
    "نمای تصویری از لایه هماهنگ‌سازی هوش مصنوعی سازمانی، داده‌ها و جریان‌های کاری",
    CssClass: "page-hero--home"))

<section class="home-signal-band">
    <div class="container home-signal-grid">
        <div class="home-signal glass-surface">
            <span class="home-signal__icon" aria-hidden="true"><svg><use href="#icon-server"></use></svg></span>
            <strong>نصب On-Premise</strong>
            <span>اجرا روی سرورها، شبکه و دامنه داخلی سازمان.</span>
        </div>
        <div class="home-signal glass-surface">
            <span class="home-signal__icon" aria-hidden="true"><svg><use href="#icon-shield"></use></svg></span>
            <strong>کنترل نقش و دسترسی</strong>
            <span>مدیریت کاربران، سطح دسترسی، لاگ و سیاست استفاده.</span>
        </div>
        <div class="home-signal glass-surface">
            <span class="home-signal__icon" aria-hidden="true"><svg><use href="#icon-flow"></use></svg></span>
            <strong>اتصال به ERP و API</strong>
            <span>اتصال کنترل‌شده به داده‌ها و سامانه‌های عملیاتی.</span>
        </div>
        <div class="home-signal glass-surface">
            <span class="home-signal__icon" aria-hidden="true"><svg><use href="#icon-chart"></use></svg></span>
            <strong>گزارش مصرف و هزینه</strong>
            <span>پایش درخواست‌ها، مصرف مدل‌ها، هزینه و کیفیت پاسخ.</span>
        </div>
    </div>
</section>

<section class="content-band">
    <div class="container">
        <article class="home-product-spotlight glass-surface" aria-labelledby="home-product-spotlight-title">
            <div class="home-product-spotlight__grid">
                <div class="home-product-spotlight__copy">
                    <span class="home-product-spotlight__eyebrow">محصول ویژه</span>
                    <h2 id="home-product-spotlight-title">هوش‌یاران؛ پلتفرم هوش مصنوعی سازمانی</h2>
                    <p>
                        هوش‌یاران استفاده از مدل‌های محلی و ابری، چت سازمانی، پایگاه دانش هوشمند، چت بات سازمانی، ایجنت‌ها،
                        داشبورد و کنترل مصرف را از یک پنل واحد به داده‌ها و فرایندهای داخلی سازمان وصل می‌کند.
                    </p>
                    <ul class="home-product-spotlight__list">
                        <li>یک مسیر واحد برای کارکنان، مدیران و تیم فناوری اطلاعات</li>
                        <li>کنترل مدل‌ها، داده‌ها، نقش‌ها و مصرف در سطح سازمان</li>
                        <li>استقرار روی زیرساخت یا زیردامنه داخلی سازمان</li>
                    </ul>
                    <div class="home-product-spotlight__actions">
                        <a class="button button--primary" href="/ai-integrator">مشاهده پلتفرم</a>
                        <a class="text-link text-link--icon" href="/request-demo">
                            درخواست جلسه معرفی
                            <svg aria-hidden="true"><use href="#icon-arrow-left"></use></svg>
                        </a>
                    </div>
                </div>
                <figure class="home-product-spotlight__media">
                    <div class="home-product-spotlight__frame">
                        <img src="~/landing-pages/ai-integrator/screenshots/home-clean.webp"
                             alt="نمایی از محیط یکپارچه‌ساز"
                             width="1585"
                             height="991"
                             loading="lazy"
                             decoding="async" />
                    </div>
                    <figcaption>نمایی از محیط یکپارچه‌ساز</figcaption>
                </figure>
            </div>
        </article>
    </div>
</section>

<section class="content-band content-band--alt">
    <div class="container">
        @await Html.PartialAsync("_SectionTitle", new SectionTitleViewModel(
            "محصولات",
            "نرم افزار هوش مصنوعی سازمانی برای نیازهای واقعی شرکت‌ها",
            "محصولات هوش‌یاران برای چت بات سازمانی، پایگاه دانش، مدیریت مدل‌های زبانی، اتوماسیون فرایندها و استفاده امن از AI طراحی شده‌اند."))
        <div class="product-grid">
            @foreach (var product in Model.FeaturedProducts)
            {
                @await Html.PartialAsync("_ProductCard", new ProductCardViewModel(
                    product.PersianTitle,
                    CardSummary(product.ShortDescription),
                    product.ProductCategory?.Title ?? "هوش مصنوعی سازمانی",
                    $"/products/{product.Slug}",
                    "مشاهده جزئیات",
                    product.Benefits.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Take(1).ToArray(),
                    ProductImage(product)))
            }
        </div>
    </div>
</section>

<section class="content-band">
    <div class="container">
        @await Html.PartialAsync("_SectionTitle", new SectionTitleViewModel(
            "بانک دانش",
            "بانک دانش هوش مصنوعی سازمانی",
            "راهنماهایی برای پیاده سازی هوش مصنوعی در سازمان، چت با اسناد سازمانی، AI خصوصی و مدیریت مدل‌های زبانی."))
        <div class="article-grid">
            @foreach (var article in Model.LatestArticles)
            {
                <article class="article-card">
                    @if (!string.IsNullOrWhiteSpace(article.ImagePath))
                    {
                        <img class="article-card__image" src="@AssetOptimizer.Thumbnail(article.ImagePath)" alt="@article.Title" width="1100" height="619" loading="lazy" decoding="async" />
                    }
                    <h3>@article.Title</h3>
                    <span>@article.Summary</span>
                    <div class="article-card__footer">
                        <span class="article-card__date">
                            <svg aria-hidden="true"><use href="#icon-calendar"></use></svg>
                            @PersianDateFormatter.ToPersianDate(article.PublishedAt)
                        </span>
                        <a class="text-link text-link--icon" href="/blog/@article.Slug">
                            ادامه مطلب
                            <svg aria-hidden="true"><use href="#icon-arrow-left"></use></svg>
                        </a>
                    </div>
                </article>
            }
        </div>
    </div>
</section>

<section class="content-band content-band--alt">
    <div class="container">
        @await Html.PartialAsync("_CtaSection", new CtaSectionViewModel(
            "مسیر AI خصوصی سازمانتان را دقیق شروع کنید",
            "در جلسه معرفی، داده‌ها، سطح حساسیت، سناریوهای کاربردی و مسیر راه اندازی هوش مصنوعی سازمانی برای شما بررسی می‌شود.",
            "درخواست جلسه معرفی",
            "/request-demo",
            "صفحه راه‌اندازی",
            "/enterprise-ai-implementation"))
    </div>
</section>
