@page "/solutions"
@model Hooshyaran.Web.Pages.Solutions.IndexModel
@inject Hooshyaran.Web.Services.ICmsHtmlService CmsHtml
@{
    ViewData["Title"] = Model.Seo?.Title ?? Model.PageContent?.SeoTitle ?? Model.PageContent?.Title ?? "راهکارها";
    ViewData["Description"] = Model.Seo?.Description ?? Model.PageContent?.SeoDescription ?? Model.PageContent?.Summary ?? "راهکارهای هوش مصنوعی سازمانی برای صنایع مختلف.";
    ViewData["Keywords"] = Model.Seo?.Keywords ?? Model.PageContent?.SeoKeywords ?? "";
    ViewData["CanonicalPath"] = Model.Seo?.CanonicalPath ?? "/solutions";
}

@await Html.PartialAsync("_PageHero", new PageHeroViewModel(
    "راهکارها",
    Model.PageContent?.Title ?? "راهکارهای AI برای صنایع مختلف",
    Model.PageContent?.Summary ?? "مسیرهای پیشنهادی برای ورود کنترل‌شده هوش مصنوعی به فرایندهای واقعی سازمان، از داده و امنیت تا اتوماسیون و تجربه مشتری.",
    "درخواست مشاوره",
    "/contact"))

<section class="content-band">
    <div class="container">
        <article class="solutions-content cms-content">
            @Html.Raw(CmsHtml.ToSafeHtml(Model.PageContent?.Body ?? """
                <h2>راهکارهای صنعتی هوش مصنوعی سازمانی</h2>
                <p>محتوای این صفحه از پنل مدیریت و دیتابیس قابل تکمیل است.</p>
                """))
        </article>
        @if (Model.PageContent?.StaticPageTags.Any() == true)
        {
            <div class="solutions-tags">
                @await Html.PartialAsync("_TagChips", Model.PageContent.StaticPageTags.Select(item => item.Tag!).Where(tag => tag is not null))
            </div>
        }
    </div>
</section>
